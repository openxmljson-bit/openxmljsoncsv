<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime exceptions a PyInstaller + PySide6 (Qt) + Rust app
         needs to launch under the hardened runtime and pass notarization.
         These are acceptable for Developer ID (direct) distribution; the Mac
         App Store would not allow disable-library-validation. -->

    <!-- Python's interpreter maps writable+executable memory. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Load the bundled Qt/Python dylibs and the Rust extension even though
         they were not all signed by this same team. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- PyInstaller's bootloader sets DYLD_* to find bundled libraries. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>
